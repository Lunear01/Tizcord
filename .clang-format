---
# Base style for C development
BasedOnStyle: Google

# Language-specific settings
Language: Cpp
Standard: c17

# Core layout (Google defaults to 2, many C devs prefer 4)
ColumnLimit: 80
UseTab: Always
TabWidth: 4

# Bracing style (Keep it on the same line for C11/Google)
BreakBeforeBraces: Attach
AllowShortFunctionsOnASingleLine: Empty

# Pointer alignment (int* p vs int *p)
# Google prefers 'Right' for C (int *p), but 'Left' is also common.
PointerAlignment: Right

# C-specific formatting
AlignAfterOpenBracket: Align
AlignConsecutiveMacros: true
AlignConsecutiveAssignments: false
AlignEscapedNewlines: Right

# Sorting includes (keeps your headers tidy)
SortIncludes: true
IncludeBlocks: Regroup
...